# Copy this file to .env and fill in strong values before running docker compose up

# MySQL root password (used only by MySQL's own init process)
MYSQL_ROOT_PASSWORD=change_me_root

# Application database and credentials
MYSQL_DATABASE=password_app
MYSQL_USER=appuser
MYSQL_PASSWORD=change_me_appuser

# AES-256-GCM key for password encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars

# Node environment
NODE_ENV=production
